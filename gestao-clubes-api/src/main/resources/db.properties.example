# ============================================
# Configurações da Base de Dados MySQL
# ============================================
# IMPORTANTE: Copia este ficheiro para db.properties e preenche com os teus valores!

# URL de conexão (JDBC) - Aiven Cloud
db.url=jdbc:mysql://seu_host_aqui:16204/gestao_clubes?useSSL=true&requireSSL=true&serverSslCert=classpath:cert/ca.pem

# Utilizador da base de dados
db.username=seu_username_aqui

# Palavra-chave da base de dados
db.password=sua_password_aqui

# Driver JDBC
db.driver=com.mysql.cj.jdbc.Driver

# Caminho do certificado SSL
db.ssl.cert.path=cert/ca.pem
